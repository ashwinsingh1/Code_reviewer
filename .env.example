# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional overrides ────────────────────────────────────────
# Claude model to use (default: claude-3-5-sonnet-20241022)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Max tokens in Claude response (default: 8000)
# CLAUDE_MAX_TOKENS=8000

# Server bind address and port (default: 127.0.0.1:7000)
# HOST=127.0.0.1
# PORT=7000

# GitHub personal access token — only needed for private repos
# GITHUB_TOKEN=ghp_...

# Max total characters of source code sent to Claude per review (default: 80000)
# MAX_CODE_CHARS=80000

# Max number of files to include per review (default: 60)
# MAX_FILES=60

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
